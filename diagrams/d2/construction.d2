vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
construction_internal: "Construction & Structural Engineering — Internal Structure" {
  construction_building-materials: "Building Materials & Methods"
  construction_structural-engineering: Structural Engineering
  construction_industrial-buildings: "Industrial Buildings & Heavy Foundations"
}

# ==================== DOMAIN NODE ====================
construction: "Construction & Structural Engineering"

# ==================== EXTERNAL DEPENDENCIES ====================
ceramics_lime: Lime Production {
  shape: rectangle
}
chemistry_cement: "Cement & Concrete" {
  shape: rectangle
}
economics-organization_division-of-labor: Division of Labor {
  shape: rectangle
}
energy_electricity: "Electricity Generation & Distribution" {
  shape: rectangle
}
foundations: Foundations {
  shape: rectangle
}
foundations_tools-basic: "Stone & Wood Tools" {
  shape: rectangle
}
machine-tools: Machine Tools Bootstrap {
  shape: rectangle
}
metals: Metals {
  shape: rectangle
}
metals_iron-steel: "Iron & Steel Production" {
  shape: rectangle
}
textiles_rope-making: Rope and Cordage {
  shape: rectangle
}

# ==================== EDGES ====================
construction -> foundations: { class: tool-edge }
construction -> ceramics_lime: { class: material-edge }
construction -> chemistry_cement: { class: material-edge }
construction -> metals: { class: material-edge }
construction -> textiles_rope-making: { class: material-edge }
construction -> machine-tools: { class: tool-edge }
construction_building-materials -> foundations_tools-basic: { class: tool-edge }
construction_structural-engineering -> metals_iron-steel: { class: material-edge }
construction_industrial-buildings -> energy_electricity: { class: tool-edge }
construction_industrial-buildings -> economics-organization_division-of-labor: { class: tool-edge }

# ==================== STYLING ====================
construction.class: domain
construction_building-materials.class: capability
construction_structural-engineering.class: capability
construction_industrial-buildings.class: capability
ceramics_lime.class: external
chemistry_cement.class: external
economics-organization_division-of-labor.class: external
energy_electricity.class: external
foundations.class: external
foundations_tools-basic.class: external
machine-tools.class: external
metals.class: external
metals_iron-steel.class: external
textiles_rope-making.class: external

# ==================== LEGEND ====================
d2-legend: "Edge Types" {
  class: legend
  mat: "Solid arrow = material prerequisite (physical input consumed)" {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool: "Dashed arrow = tool prerequisite (equipment/infrastructure needed)" {
    style: {
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}
