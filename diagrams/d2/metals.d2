  shape: rectangle
}
energy_fuels_coke: Coke Production {
  shape: rectangle
}
energy_gravity_water-turbines: Water Turbines {
  shape: rectangle
}
energy_steam-power: Steam Power {
  shape: rectangle
}
energy_steam-power_steam-turbines: Steam Turbines {
  shape: rectangle
}
energy_storage: "Energy Storage & Diversification" {
  shape: rectangle
}
foundations: Foundations {
  shape: rectangle
}
foundations_fire: Fire-Making {
  shape: rectangle
}
knowledge_printing: Paper and Printing Press {
  shape: rectangle
}
machine-tools: Machine Tools Bootstrap {
  shape: rectangle
}
machine-tools_casting: Metal Casting {
  shape: rectangle
}
machine-tools_forming: Metal Forming {
  shape: rectangle
}
machine-tools_joining: Metal Joining {
  shape: rectangle
}
measurement_precision-metrology: "Precision Metrology & Standards" {
  shape: rectangle
}
measurement_temperature-pressure: "Temperature & Pressure Measurement" {
  shape: rectangle
}
mining: "Mining Engineering & Extractive Metallurgy" {
  shape: rectangle
}
transport: "Transportation & Logistics" {
  shape: rectangle
}
transport_railways: Railways {
  shape: rectangle
}
transport_telegraph: Telegraph Communication {
  shape: rectangle
}

# ==================== EDGES ====================
metals_iron-steel -> metals_copper-bronze: { class: tool-edge }
metals_iron-steel_blast-furnace -> metals_iron-steel: { class: tool-edge }
metals -> foundations: { class: tool-edge }
metals -> mining: { class: material-edge }
