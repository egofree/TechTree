  "id": "silicon.mg-si-production",
  "name": "Metallurgical-Grade Silicon Production",
  "level": "capability",
  "parent": "silicon",
  "description": "Carbothermic reduction of quartz (SiO₂ + 2C → Si + 2CO) in submerged arc electric furnace at 1800-2100°C. Requires 5-30 MW power, produces 97-99% purity MG-Si. Energy consumption: ~11-13 kWh/kg. The starting material for all semiconductor-grade silicon.",
  "timeline": "Years 30-40",
  "outputs": [
    "mg_silicon"
  ],
