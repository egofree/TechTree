vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
agriculture_internal: "Agriculture — Internal Structure" {
  agriculture_aquaponics: Aquaponics
  agriculture_hydroponic-ph-control: Hydroponic pH Control
  agriculture_soil-management: "Soil Management & Composting"
  agriculture_soil-management_vermiculture: Vermiculture
}

# ==================== DOMAIN NODE ====================
agriculture: Agriculture

# ==================== EXTERNAL DEPENDENCIES ====================
animals: "Animals & Animal Husbandry" {
  shape: rectangle
}
animals_aquaculture: "Aquaculture & Fisheries" {
  shape: rectangle
}
chemistry_electrodialysis: Electrodialysis {
  shape: rectangle
}
energy_electricity: "Electricity Generation & Distribution" {
  shape: rectangle
}
foundations_food-agriculture: "Agriculture & Food Production" {
  shape: rectangle
}

# ==================== EDGES ====================
agriculture_aquaponics -> agriculture: { class: tool-edge }
agriculture_hydroponic-ph-control -> agriculture_aquaponics: { class: tool-edge }
agriculture_soil-management_vermiculture -> agriculture_soil-management: { class: material-edge }
agriculture_soil-management -> agriculture: { class: tool-edge }
agriculture_aquaponics -> animals_aquaculture: { class: tool-edge }
agriculture_hydroponic-ph-control -> energy_electricity: { class: material-edge }
agriculture_soil-management -> animals: { class: material-edge }
chemistry_electrodialysis -> agriculture_hydroponic-ph-control: { class: tool-edge }
foundations_food-agriculture -> agriculture_soil-management: { class: material-edge }

# ==================== STYLING ====================
agriculture.class: domain
agriculture_aquaponics.class: capability
agriculture_hydroponic-ph-control.class: capability
agriculture_soil-management.class: earlyWin
agriculture_soil-management_vermiculture.class: earlyWin
animals.class: external
animals_aquaculture.class: external
chemistry_electrodialysis.class: external
energy_electricity.class: external
foundations_food-agriculture.class: external

# ==================== LEGEND ====================
d2-legend: "Edge Types" {
  class: legend
  mat: "Solid arrow = material prerequisite (physical input consumed)" {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool: "Dashed arrow = tool prerequisite (equipment/infrastructure needed)" {
    style: {
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}
