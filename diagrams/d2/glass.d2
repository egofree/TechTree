vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
glass_internal: "Glass — Internal Structure" {
  glass_advanced_glassblowing: Glassblowing and Scientific Apparatus
  glass_advanced: Advanced Glass Production
  glass_basic: Basic Glass Production
  glass_fibers: Glass Fiber Production
  glass_photomask-substrates: "Photomask Glass Substrates & ULE Glass"
}

# ==================== DOMAIN NODE ====================
glass: Glass

# ==================== EXTERNAL DEPENDENCIES ====================
chemistry: Chemistry {
  shape: rectangle
}
chemistry_acids: Mineral Acid Production {
  shape: rectangle
}
chemistry_refractories: Refractory Materials {
  shape: rectangle
}
cleanrooms: Clean Room Technology {
  shape: rectangle
}
electronics_assembly: Electronics Assembly {
  shape: rectangle
}
energy: Energy {
  shape: rectangle
}
energy_fuels: Fuel Production {
  shape: rectangle
}
machine-tools: Machine Tools Bootstrap {
  shape: rectangle
}
mining: "Mining Engineering & Extractive Metallurgy" {
  shape: rectangle
}
optics_inspection: Optical Inspection {
  shape: rectangle
}
photolithography_fab-processes: Core Fab Processes {
  shape: rectangle
}
photolithography_resists-masks: "Photoresists, Masks & Lithography" {
  shape: rectangle
}
polymers_composites: Composite Materials {
  shape: rectangle
}
silicon: Silicon {
  shape: rectangle
}
silicon_crystal-growth: "Crystal Growth & Wafering" {
  shape: rectangle
}
telecom: Telecommunications {
  shape: rectangle
}
telecom_radio: Radio Communication {
  shape: rectangle
}

# ==================== EDGES ====================
glass_advanced_glassblowing -> glass_advanced: { class: tool-edge }
glass_advanced -> glass_basic: { class: tool-edge }
glass_basic -> glass_basic: { class: material-edge }
glass_fibers -> glass_advanced: { class: material-edge }
glass_fibers -> glass: { class: tool-edge }
glass_photomask-substrates -> glass_advanced: { class: tool-edge }
chemistry_acids -> glass_basic: { class: tool-edge }
cleanrooms -> glass: { class: material-edge }
electronics_assembly -> glass_fibers: { class: material-edge }
glass_advanced_glassblowing -> energy_fuels: { class: tool-edge }
glass_basic -> mining: { class: material-edge }
glass_photomask-substrates -> photolithography_fab-processes: { class: material-edge }
glass -> chemistry_refractories: { class: material-edge }
glass -> chemistry: { class: material-edge }
glass -> energy: { class: material-edge }
glass -> machine-tools: { class: tool-edge }
optics_inspection -> glass_advanced: { class: material-edge }
photolithography_resists-masks -> glass_basic: { class: material-edge }
polymers_composites -> glass_fibers: { class: material-edge }
silicon_crystal-growth -> glass_advanced: { class: material-edge }
silicon -> glass: { class: tool-edge }
telecom_radio -> glass: { class: material-edge }
telecom -> glass: { class: material-edge }

# ==================== STYLING ====================
glass.class: domain
glass_advanced_glassblowing.class: process
glass_advanced.class: capability
glass_basic.class: capability
glass_fibers.class: capability
glass_photomask-substrates.class: capability
chemistry.class: external
chemistry_acids.class: external
chemistry_refractories.class: external
cleanrooms.class: external
electronics_assembly.class: external
energy.class: external
energy_fuels.class: external
machine-tools.class: external
mining.class: external
optics_inspection.class: external
photolithography_fab-processes.class: external
photolithography_resists-masks.class: external
polymers_composites.class: external
silicon.class: external
silicon_crystal-growth.class: external
telecom.class: external
telecom_radio.class: external

# ==================== LEGEND ====================
d2-legend: "Edge Types" {
  class: legend
  mat: "Solid arrow = material prerequisite (physical input consumed)" {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool: "Dashed arrow = tool prerequisite (equipment/infrastructure needed)" {
    style: {
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}
