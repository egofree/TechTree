{
  "@context": "../../context.jsonld",
  "@type": "Capability",
  "id": "metals.aluminum",
  "name": "Aluminum Production",
  "level": "capability",
  "parent": "metals",
  "description": "Bayer process converts bauxite to alumina; Hall-Héroult electrolytic reduction of alumina in molten cryolite at 960-980°C produces aluminum at 13-15 kWh/kg. Aluminum alloys (1xxx-8xxx series) for structural, aerospace, electrical, and packaging applications. Extrusion, die casting, and 95% energy savings from recycling.",
  "timeline": "Years 20-40",
  "outputs": [
    "aluminum_ingots",
    "aluminum_extrusions",
    "aluminum_castings",
    "aluminum_sheet"
  ],
  "critical": false,
  "early_win": false,
  "pinnacle": false,
