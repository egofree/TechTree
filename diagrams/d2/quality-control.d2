vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
quality-control_internal: "Quality Control & Statistical Process Control — Internal Structure" {
  quality-control_spc: Statistical Process Control
  quality-control_inspection-sampling: "Inspection & Sampling Plans"
  quality-control_defect-analysis: "Defect Analysis & Yield Modeling"
}

# ==================== DOMAIN NODE ====================
quality-control: "Quality Control & Statistical Process Control"

# ==================== EXTERNAL DEPENDENCIES ====================
automation_process-control: "Process Control & Lot Tracking" {
  shape: rectangle
}
computing: "Computing & Automation" {
  shape: rectangle
}
knowledge: "Knowledge Preservation & Education" {
  shape: rectangle
}
measurement: "Measurement & Instrumentation" {
  shape: rectangle
}
measurement_precision-metrology: "Precision Metrology & Standards" {
  shape: rectangle
}
photolithography: "Photolithography & IC Fabrication" {
  shape: rectangle
}
vlsi-scaling: "VLSI Scaling & Advanced Semiconductor" {
  shape: rectangle
}

# ==================== EDGES ====================
quality-control_spc -> quality-control: { class: tool-edge }
quality-control_inspection-sampling -> quality-control: { class: tool-edge }
quality-control_defect-analysis -> quality-control: { class: tool-edge }
quality-control_defect-analysis -> quality-control_spc: { class: tool-edge }
quality-control -> measurement: { class: tool-edge }
quality-control -> computing: { class: tool-edge }
quality-control -> knowledge: { class: tool-edge }
quality-control_spc -> measurement: { class: tool-edge }
quality-control_inspection-sampling -> measurement_precision-metrology: { class: tool-edge }
vlsi-scaling -> quality-control: { class: tool-edge }
photolithography -> quality-control: { class: tool-edge }
automation_process-control -> quality-control: { class: tool-edge }

# ==================== STYLING ====================
quality-control.class: domain
quality-control_spc.class: capability
quality-control_inspection-sampling.class: capability
quality-control_defect-analysis.class: capability
automation_process-control.class: external
computing.class: external
knowledge.class: external
measurement.class: external
measurement_precision-metrology.class: external
photolithography.class: external
vlsi-scaling.class: external

# ==================== LEGEND ====================
d2-legend: "Edge Types" {
  class: legend
  mat: "Solid arrow = material prerequisite (physical input consumed)" {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool: "Dashed arrow = tool prerequisite (equipment/infrastructure needed)" {
    style: {
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}
