vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
metals_internal: "Metals — Internal Structure" {
  metals_copper-bronze: "Copper & Bronze Production"
  metals_iron-steel: "Iron & Steel Production"
  metals_iron-steel_blast-furnace: Blast Furnace and Cast Iron
  metals_steelmaking: Modern Steelmaking
  metals_aluminum: Aluminum Production
  metals_aluminum_semiconductor-grade: Semiconductor-Grade Aluminum Production
  metals_non-ferrous: Non-Ferrous Metal Production
  metals_alloys: Specialty Alloys
  metals_forming: Primary Metal Forming
  metals_finishing: "Metal Finishing & Surface Treatment"
  metals_powder-metallurgy: "Powder Metallurgy & Advanced Materials"
  metals_refractory-specialty: "Refractory & Specialty Metals for Semiconductor Manufacturing"
  metals_specialty-semiconductor: "Specialty Metals for Semiconductor Interconnects & Barrier Layers"
  metals_precious-metals: "Precious Metal Production (Gold & Silver)"
}

# ==================== DOMAIN NODE ====================
metals: Metals

