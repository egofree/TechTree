health.class: domain
health_sanitation.class: capability
health_medicine.class: capability
health_pharmacology.class: capability
health_pharmaceutical-production.class: critical
health_surgery-basics.class: critical
health_diagnostics.class: capability
health_occupational-health.class: capability
health_medical-instruments.class: capability
animals_beekeeping.class: external
ceramics.class: external
chemistry.class: external
chemistry_acids.class: external
chemistry_ammonia.class: external
chemistry_distillation.class: external
chemistry_soap.class: external
chemistry_solvents.class: external
