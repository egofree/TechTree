vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
vlsi-scaling_internal: "VLSI Scaling & Advanced Semiconductor — Internal Structure" {
  vlsi-scaling_advanced-lithography: Advanced Lithography
  vlsi-scaling_advanced-processes: Advanced Processes
  vlsi-scaling_continuous-scaling: Continuous Scaling
  vlsi-scaling_eda-design: "EDA, GPU Design & Advanced Packaging"
}

# ==================== DOMAIN NODE ====================
vlsi-scaling: "VLSI Scaling & Advanced Semiconductor"

# ==================== EXTERNAL DEPENDENCIES ====================
chemistry_dopant-etch-gases: "Dopant & Etch Gases" {
  shape: rectangle
}
computing: "Computing & Automation" {
  shape: rectangle
}
electronics_assembly: Electronics Assembly {
  shape: rectangle
}
metals_specialty-semiconductor: "Specialty Metals for Semiconductor Interconnects & Barrier Layers" {
  shape: rectangle
}
optics_inspection: Optical Inspection {
  shape: rectangle
}
photolithography: "Photolithography & IC Fabrication" {
  shape: rectangle
}
photolithography_fab-processes: Core Fab Processes {
  shape: rectangle
}
photolithography_resists-masks: "Photoresists, Masks & Lithography" {
  shape: rectangle
}
quality-control: "Quality Control & Statistical Process Control" {
  shape: rectangle
}
silicon_basic-devices: Basic Semiconductor Devices {
  shape: rectangle
}

# ==================== EDGES ====================
metals_specialty-semiconductor -> vlsi-scaling_advanced-processes: { class: tool-edge }
vlsi-scaling_advanced-lithography -> optics_inspection: { class: tool-edge }
vlsi-scaling_advanced-lithography -> photolithography_resists-masks: { class: tool-edge }
vlsi-scaling_advanced-processes -> photolithography_fab-processes: { class: tool-edge }
vlsi-scaling_continuous-scaling -> photolithography_fab-processes: { class: tool-edge }
vlsi-scaling_eda-design -> chemistry_dopant-etch-gases: { class: tool-edge }
vlsi-scaling_eda-design -> computing: { class: tool-edge }
vlsi-scaling_eda-design -> electronics_assembly: { class: tool-edge }
vlsi-scaling_eda-design -> photolithography_fab-processes: { class: tool-edge }
vlsi-scaling_eda-design -> silicon_basic-devices: { class: tool-edge }
vlsi-scaling -> photolithography: { class: tool-edge }
vlsi-scaling -> quality-control: { class: tool-edge }

# ==================== STYLING ====================
vlsi-scaling.class: domain
vlsi-scaling_advanced-lithography.class: capability
vlsi-scaling_advanced-processes.class: capability
vlsi-scaling_continuous-scaling.class: capability
vlsi-scaling_eda-design.class: capability
chemistry_dopant-etch-gases.class: external
computing.class: external
electronics_assembly.class: external
metals_specialty-semiconductor.class: external
optics_inspection.class: external
photolithography.class: external
photolithography_fab-processes.class: external
photolithography_resists-masks.class: external
quality-control.class: external
silicon_basic-devices.class: external

# ==================== LEGEND ====================
d2-legend: "Edge Types" {
  class: legend
  mat: "Solid arrow = material prerequisite (physical input consumed)" {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool: "Dashed arrow = tool prerequisite (equipment/infrastructure needed)" {
    style: {
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}
