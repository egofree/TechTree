vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
vacuum_internal: "Vacuum Technology — Internal Structure" {
  vacuum_pumps: Vacuum Pumps
  vacuum_chambers: "Vacuum Chambers & Sealing"
  vacuum_measurement: "Vacuum Measurement & Leak Detection"
}

# ==================== DOMAIN NODE ====================
vacuum: Vacuum Technology

# ==================== EXTERNAL DEPENDENCIES ====================
automation_wafer-handling: Wafer Handling Robots {
  shape: rectangle
}
energy_electricity: "Electricity Generation & Distribution" {
  shape: rectangle
}
gas-handling: Gas Handling {
  shape: rectangle
}
machine-tools: Machine Tools Bootstrap {
  shape: rectangle
}
machine-tools_joining_electron-beam: Electron Beam Welding {
  shape: rectangle
}
machine-tools_joining_tig-welding: "TIG Welding (GTAW)" {
  shape: rectangle
}
measurement: "Measurement & Instrumentation" {
  shape: rectangle
}
metals: Metals {
  shape: rectangle
}
optics_inspection_optical-coatings: Optical Coatings {
  shape: rectangle
}
photolithography_fab-processes: Core Fab Processes {
  shape: rectangle
}
silicon_basic-devices: Basic Semiconductor Devices {
  shape: rectangle
}

# ==================== EDGES ====================
vacuum -> gas-handling: { class: tool-edge }
vacuum -> energy_electricity: { class: tool-edge }
vacuum -> metals: { class: material-edge }
vacuum -> measurement: { class: tool-edge }
vacuum_pumps -> machine-tools: { class: tool-edge }
vacuum_chambers -> machine-tools: { class: tool-edge }
vacuum_chambers -> metals: { class: material-edge }
vacuum_measurement -> measurement: { class: tool-edge }
silicon_basic-devices -> vacuum_pumps: { class: tool-edge }
photolithography_fab-processes -> vacuum_pumps: { class: tool-edge }
optics_inspection_optical-coatings -> vacuum_pumps: { class: tool-edge }
automation_wafer-handling -> vacuum: { class: tool-edge }
machine-tools_joining_electron-beam -> vacuum: { class: tool-edge }
vacuum_chambers -> machine-tools_joining_tig-welding: { class: tool-edge }
vacuum_chambers -> machine-tools_joining_electron-beam: { class: tool-edge }

# ==================== STYLING ====================
vacuum.class: domain
vacuum_pumps.class: capability
vacuum_chambers.class: capability
vacuum_measurement.class: capability
automation_wafer-handling.class: external
energy_electricity.class: external
gas-handling.class: external
machine-tools.class: external
machine-tools_joining_electron-beam.class: external
machine-tools_joining_tig-welding.class: external
measurement.class: external
metals.class: external
optics_inspection_optical-coatings.class: external
photolithography_fab-processes.class: external
silicon_basic-devices.class: external

# ==================== LEGEND ====================
d2-legend: "Edge Types" {
  class: legend
  mat: "Solid arrow = material prerequisite (physical input consumed)" {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool: "Dashed arrow = tool prerequisite (equipment/infrastructure needed)" {
    style: {
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}
