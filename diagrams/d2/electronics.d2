vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
electronics_internal: "Electronics — Internal Structure" {
  electronics_assembly: Electronics Assembly
  electronics_electrical-systems: Electrical Systems
}

# ==================== DOMAIN NODE ====================
electronics: Electronics

# ==================== EXTERNAL DEPENDENCIES ====================
automation: "Automation & Robotics" {
  shape: rectangle
}
automation_equipment-communication: Equipment Communication {
  shape: rectangle
}
chemistry: Chemistry {
  shape: rectangle
}
chemistry_electrolysis: Electrolysis {
  shape: rectangle
}
computing_electronic: Electronic Computing {
  shape: rectangle
}
energy_electricity: "Electricity Generation & Distribution" {
  shape: rectangle
}
glass_fibers: Glass Fiber Production {
  shape: rectangle
}
machine-tools: Machine Tools Bootstrap {
  shape: rectangle
}
metals: Metals {
  shape: rectangle
}
polymers_thermoplastics: Thermoplastic Polymers {
  shape: rectangle
}
polymers_thermosets: Thermosetting Polymers {
  shape: rectangle
}
silicon_basic-devices: Basic Semiconductor Devices {
  shape: rectangle
}
vlsi-scaling_eda-design: "EDA, GPU Design & Advanced Packaging" {
  shape: rectangle
}

# ==================== EDGES ====================
electronics -> metals: { class: material-edge }
electronics -> energy_electricity: { class: tool-edge }
electronics -> machine-tools: { class: tool-edge }
electronics -> chemistry: { class: material-edge }
electronics_assembly -> silicon_basic-devices: { class: material-edge }
electronics_assembly -> glass_fibers: { class: material-edge }
electronics_assembly -> polymers_thermosets: { class: material-edge }
electronics_electrical-systems -> energy_electricity: { class: tool-edge }
electronics_electrical-systems -> chemistry_electrolysis: { class: material-edge }
electronics_electrical-systems -> polymers_thermoplastics: { class: material-edge }
computing_electronic -> electronics_assembly: { class: tool-edge }
vlsi-scaling_eda-design -> electronics_assembly: { class: tool-edge }
automation -> electronics: { class: tool-edge }
automation_equipment-communication -> electronics: { class: tool-edge }

# ==================== STYLING ====================
electronics.class: domain
electronics_assembly.class: capability
electronics_electrical-systems.class: capability
automation.class: external
automation_equipment-communication.class: external
chemistry.class: external
chemistry_electrolysis.class: external
computing_electronic.class: external
energy_electricity.class: external
glass_fibers.class: external
machine-tools.class: external
metals.class: external
polymers_thermoplastics.class: external
polymers_thermosets.class: external
silicon_basic-devices.class: external
vlsi-scaling_eda-design.class: external

# ==================== LEGEND ====================
d2-legend: "Edge Types" {
  class: legend
  mat: "Solid arrow = material prerequisite (physical input consumed)" {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool: "Dashed arrow = tool prerequisite (equipment/infrastructure needed)" {
    style: {
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}
