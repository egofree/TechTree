vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    center: true
  }
}

direction: down

classes: {
  domain: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 4
    }
  }
  capability: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 2
    }
  }
  process: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
  }
  critical: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 3
      bold: true
    }
  }
  earlyWin: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
    }
  }
  pinnacle: {
    style: {
      fill: "#fce4ec"
      stroke: "#c62828"
      stroke-width: 3
      bold: true
    }
  }
  external: {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      stroke-width: 1
    }
  }
  legend: {
    style: {
      fill: "#fafafa"
      stroke: "#bdbdbd"
      stroke-width: 1
      font-size: 13
    }
  }
  material-edge: {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool-edge: {
    style: {
      stroke: "#666666"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}

# ==================== INTERNAL NODES ====================
ceramics_internal: "Ceramics & Refractories — Internal Structure" {
  ceramics_pottery: "Pottery & Clay Products"
  ceramics_pottery_kiln-firing: Kiln Firing
  ceramics_kilns: Kiln Construction
  ceramics_lime: Lime Production
  ceramics_advanced-ceramics: "Advanced Ceramics & Refractories"
}

# ==================== DOMAIN NODE ====================
ceramics: "Ceramics & Refractories"

# ==================== EXTERNAL DEPENDENCIES ====================
chemistry_cement: "Cement & Concrete" {
  shape: rectangle
}
chemistry_refractories: Refractory Materials {
  shape: rectangle
}
energy_fuels_charcoal: Charcoal Production {
  shape: rectangle
}
energy_fuels_coal: "Coal Mining & Combustion" {
  shape: rectangle
}
energy_fuels_coke: Coke Production {
  shape: rectangle
}
foundations: Foundations {
  shape: rectangle
}
foundations_fire: Fire-Making {
  shape: rectangle
}
foundations_tools-basic: "Stone & Wood Tools" {
  shape: rectangle
}
health_sanitation: "Water Supply & Sanitation" {
  shape: rectangle
}
metals: Metals {
  shape: rectangle
}
metals_iron-steel_blast-furnace: Blast Furnace and Cast Iron {
  shape: rectangle
}
mining: "Mining Engineering & Extractive Metallurgy" {
  shape: rectangle
}
photolithography_cleanrooms: Cleanrooms {
  shape: rectangle
}
silicon: Silicon {
  shape: rectangle
}

# ==================== EDGES ====================
ceramics_lime -> ceramics_kilns: { class: tool-edge }
ceramics_advanced-ceramics -> ceramics_pottery: { class: tool-edge }
ceramics_advanced-ceramics -> ceramics_kilns: { class: tool-edge }
energy_fuels_coal -> ceramics_kilns: { class: tool-edge }
energy_fuels_coke -> ceramics_kilns: { class: tool-edge }
chemistry_cement -> ceramics_kilns: { class: tool-edge }
photolithography_cleanrooms -> ceramics: { class: tool-edge }
ceramics -> foundations: { class: tool-edge }
ceramics -> metals: { class: tool-edge }
ceramics_pottery_kiln-firing -> energy_fuels_charcoal: { class: material-edge }
ceramics_pottery -> foundations_fire: { class: material-edge }
ceramics_pottery -> foundations_tools-basic: { class: tool-edge }
health_sanitation -> ceramics: { class: tool-edge }
ceramics_lime -> mining: { class: material-edge }
ceramics_advanced-ceramics -> mining: { class: material-edge }
silicon -> ceramics_advanced-ceramics: { class: tool-edge }
metals_iron-steel_blast-furnace -> ceramics_kilns: { class: tool-edge }
chemistry_refractories -> ceramics_kilns: { class: tool-edge }

# ==================== STYLING ====================
ceramics.class: domain
ceramics_pottery.class: capability
ceramics_pottery_kiln-firing.class: process
ceramics_kilns.class: capability
ceramics_lime.class: capability
ceramics_advanced-ceramics.class: critical
chemistry_cement.class: external
chemistry_refractories.class: external
energy_fuels_charcoal.class: external
energy_fuels_coal.class: external
energy_fuels_coke.class: external
foundations.class: external
foundations_fire.class: external
foundations_tools-basic.class: external
health_sanitation.class: external
metals.class: external
metals_iron-steel_blast-furnace.class: external
mining.class: external
photolithography_cleanrooms.class: external
silicon.class: external

# ==================== LEGEND ====================
d2-legend: "Edge Types" {
  class: legend
  mat: "Solid arrow = material prerequisite (physical input consumed)" {
    style: {
      stroke: "#333333"
      stroke-width: 2
    }
  }
  tool: "Dashed arrow = tool prerequisite (equipment/infrastructure needed)" {
    style: {
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}
